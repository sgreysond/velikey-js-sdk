{
  "name": "@velikey/sdk",
  "version": "0.2.0",
  "description": "VeliKey Axis JavaScript/TypeScript SDK for Aegis operator workflows",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "test": "jest --maxWorkers=50%",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "docs": "typedoc src/index.ts",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "keywords": [
    "cryptography",
    "tls",
    "security",
    "post-quantum",
    "compliance",
    "velikey",
    "aegis",
    "quantum-safe"
  ],
  "author": "VeliKey Team <sdk@velikey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/velikey/velikey-js-sdk.git"
  },
  "homepage": "https://velikey.com",
  "bugs": {
    "url": "https://github.com/velikey/velikey-js-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.12.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@swc/core": "^1.6.0",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "rollup": "^4.50.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.25.0",
    "typescript": "^5.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
