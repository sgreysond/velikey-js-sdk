# SECURITY HARDENING — supply-chain attack mitigation (added 2026-05-24).
#
# Disables lifecycle scripts by default. This blocks ~90% of recent npm
# supply-chain attacks (Shai-Hulud, @antv, TanStack, Tiledesk,
# durabletask) which all rely on postinstall/preinstall/prepare hooks
# executing during `npm install` to harvest credentials from the
# developer/CI machine.
#
# Packages that legitimately need lifecycle scripts (for native
# bindings or build-time codegen) are explicitly allowlisted by
# running `npm rebuild <pkg>` after install. The allowlist for this
# repo lives in package.json under "scripts.postinstall-trusted",
# which is invoked by `scripts/install.sh` and by the Dockerfile.
#
# Allowlist for velikey-js-sdk:
#   @swc/core   (dev) — native bundler; downloads platform-specific binary
#   fsevents    (dev, macOS-only) — file watcher native binding
#
# Note: do NOT add `ignore-scripts=true` to ~/.npmrc — that would block
# scripts for every npm operation on this machine. We want repo-scoped
# enforcement so the cooldown applies only to this codebase.
ignore-scripts=true

# Belt-and-suspenders: fail builds when a transitive dep adds a new
# postinstall script that isn't in our allowlist. (npm 10+.)
# (When this triggers, audit the new dep before allowlisting.)
fund=false
audit-level=high

# Don't trust the npm registry to do version-range resolution at install
# time — only use what's in package-lock.json. Stops a poisoned new
# minor version from being silently picked up.
engine-strict=false
save-exact=true
